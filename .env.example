# =====================================================================
# Agregado.Pro — Environment Variables Template
# Copiar este arquivo para .env.local e preencher os valores
# NUNCA commitar .env.local no repositório
# =====================================================================

# ─── Supabase (obrigatório — Phase 1) ─────────────────────────────

# URL do projeto Supabase (seguro para expor no browser)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Anon key — RLS protege os dados (seguro para expor no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NUNCA expor no frontend ou commitar
# Usado apenas em Edge Functions e operações de sistema
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Next.js (obrigatório — Phase 1) ──────────────────────────────

# URL da aplicação
NEXTAUTH_URL=http://localhost:3000

# Segredo para tokens de sessão (gerar com: openssl rand -base64 32)
NEXTAUTH_SECRET=seu_segredo_aqui_minimo_32_caracteres

# ─── BaaS — Banking (Phase 2 — não configurar antes) ──────────────

# Celcoin (recomendado) ou Swap
# BAAS_PROVIDER=celcoin
# BAAS_API_URL=https://api.celcoin.com.br
# BAAS_API_KEY=sua_api_key_baas
# BAAS_WEBHOOK_SECRET=segredo_para_validacao_hmac

# ─── Anthropic — IA de classificação (Phase 2) ────────────────────

# ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Open Finance (Phase 3) ───────────────────────────────────────

# OPEN_FINANCE_CLIENT_ID=
# OPEN_FINANCE_CLIENT_SECRET=

# ─── Monitoramento (opcional) ─────────────────────────────────────

# SENTRY_DSN=https://...
# NEXT_PUBLIC_SENTRY_DSN=https://...

# ─── Ambiente ─────────────────────────────────────────────────────

NODE_ENV=development
